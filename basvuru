<script>
  var currentStep = 1;
  var formSubmitted = false;

  function goToStep(n) {
    // Basic validation for step 1
    if (n === 2 && currentStep === 1) {
      const s1inputs = document.querySelectorAll('#step-1 [required]');
      for (let inp of s1inputs) {
        if (!inp.value.trim()) { inp.focus(); return; }
      }
    }
    // Basic validation for step 2
    if (n === 3 && currentStep === 2) {
      const s2inputs = document.querySelectorAll('#step-2 [required]');
      for (let inp of s2inputs) {
        if (!inp.value.trim()) { inp.focus(); return; }
      }
    }

    document.getElementById('step-' + currentStep).classList.remove('active');
    currentStep = n;
    document.getElementById('step-' + n).classList.add('active');

    // Update dots
    for (let i = 1; i <= 3; i++) {
      const dot = document.getElementById('dot-' + i);
      dot.classList.remove('active', 'done');
      if (i < n) dot.classList.add('done');
      else if (i === n) dot.classList.add('active');
    }
    for (let i = 1; i <= 2; i++) {
      const line = document.getElementById('line-' + i);
      line.classList.toggle('done', i < n);
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function handleSubmit() {
    formSubmitted = true;
  }

  document.getElementById('hidden_iframe').addEventListener('load', function() {
    if (formSubmitted) {
      document.getElementById('rsvpForm').style.display = 'none';
      document.getElementById('stepsIndicator').style.display = 'none';
      document.getElementById('successScreen').style.display = 'block';
      formSubmitted = false;
    }
  });
</script>

