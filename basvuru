<!DOCTYPE html>

<html lang="tr">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Başvuru — Northline Pure Drive Society</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:ital,wght@0,300;0,400;0,600;0,700;1,300&family=Barlow+Condensed:wght@400;600;700&display=swap" rel="stylesheet"/>
<style>
  :root {
    --navy: #0d1b35;
    --navy-mid: #1a2744;
    --navy-light: #243356;
    --copper: #b87333;
    --copper-bright: #d4894a;
    --copper-gold: #e8a856;
    --copper-dim: #7a4c22;
    --white: #f0ece4;
    --white-dim: #c8c0b0;
    --dark: #080f1e;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: ‘Barlow’, sans-serif;
background-color: var(–dark);
color: var(–white);
min-height: 100vh;
}

/* ─── NAV ─── */
nav {
position: fixed; top: 0; width: 100%; z-index: 100;
display: flex; justify-content: space-between; align-items: center;
padding: 18px 40px;
background: rgba(8,15,30,0.96);
border-bottom: 1px solid rgba(184,115,51,0.12);
backdrop-filter: blur(8px);
}
.nav-logo { display: flex; align-items: center; gap: 14px; text-decoration: none; }
.nav-logo img { width: 38px; height: 38px; border-radius: 50%; }
.nav-logo-text {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 14px;
letter-spacing: 0.2em; text-transform: uppercase;
color: var(–white); line-height: 1.2;
}
.nav-logo-text span {
display: block; font-size: 9px; font-weight: 400;
color: var(–copper-bright); letter-spacing: 0.35em;
}
.nav-back {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 12px; font-weight: 600; letter-spacing: 0.2em;
text-transform: uppercase; color: var(–white-dim);
text-decoration: none; display: flex; align-items: center; gap-6px;
transition: color 0.2s;
}
.nav-back:hover { color: var(–copper-bright); }

/* ─── MAIN ─── */
main {
padding-top: 100px; padding-bottom: 80px;
min-height: 100vh;
background:
radial-gradient(ellipse 60% 40% at 80% 0%, rgba(26,39,68,0.8) 0%, transparent 60%),
radial-gradient(ellipse 40% 30% at 0% 80%, rgba(184,115,51,0.06) 0%, transparent 60%),
var(–dark);
}

/* Grid bg */
main::before {
content: ‘’;
position: fixed; inset: 0; z-index: 0;
background-image:
linear-gradient(rgba(184,115,51,0.04) 1px, transparent 1px),
linear-gradient(90deg, rgba(184,115,51,0.04) 1px, transparent 1px);
background-size: 60px 60px;
pointer-events: none;
}

.container {
position: relative; z-index: 1;
max-width: 660px; margin: 0 auto; padding: 0 24px;
}

/* ─── HEADER ─── */
.page-header {
text-align: center; margin-bottom: 56px;
}

.page-tag {
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 10px; font-weight: 700;
letter-spacing: 0.5em; text-transform: uppercase;
color: var(–copper);
display: flex; align-items: center; justify-content: center; gap: 12px;
margin-bottom: 16px;
}
.page-tag::before, .page-tag::after {
content: ‘’; width: 28px; height: 1px;
background: var(–copper-dim);
}

.page-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: clamp(44px, 10vw, 80px);
letter-spacing: 0.05em; line-height: 0.9;
margin-bottom: 16px;
}

.page-desc {
font-size: 14px; font-weight: 300; color: var(–white-dim);
line-height: 1.75; max-width: 440px; margin: 0 auto;
}

/* ─── STEPS ─── */
.steps-indicator {
display: flex; align-items: center; justify-content: center;
gap: 0; margin-bottom: 48px;
}

.step-dot {
width: 32px; height: 32px;
border-radius: 50%;
border: 1.5px solid rgba(184,115,51,0.3);
display: flex; align-items: center; justify-content: center;
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 12px; font-weight: 700;
color: var(–white-dim);
transition: all 0.3s;
}
.step-dot.active {
background: var(–copper);
border-color: var(–copper);
color: var(–dark);
box-shadow: 0 0 20px rgba(184,115,51,0.35);
}
.step-dot.done {
background: rgba(184,115,51,0.15);
border-color: var(–copper-dim);
color: var(–copper);
}
.step-line {
width: 48px; height: 1px;
background: rgba(184,115,51,0.2);
transition: background 0.3s;
}
.step-line.done { background: rgba(184,115,51,0.5); }

/* ─── FORM CARD ─── */
.form-card {
background: linear-gradient(160deg, var(–navy-mid) 0%, var(–navy) 100%);
border: 1px solid rgba(184,115,51,0.15);
padding: 44px 40px;
position: relative; overflow: hidden;
}

.form-card::before {
content: ‘’;
position: absolute; top: 0; left: 0; right: 0; height: 2px;
background: linear-gradient(to right, transparent, var(–copper), transparent);
}

/* Step panels */
.step-panel { display: none; }
.step-panel.active { display: block; }

.step-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 28px; letter-spacing: 0.06em;
color: var(–copper-bright); margin-bottom: 6px;
}
.step-subtitle {
font-size: 13px; font-weight: 300; color: var(–white-dim);
margin-bottom: 32px; line-height: 1.6;
}

/* ─── FIELDS ─── */
.field-group { margin-bottom: 22px; }

.field-group label {
display: block;
font-family: ‘Barlow Condensed’, sans-serif;
font-size: 10px; font-weight: 700;
letter-spacing: 0.35em; text-transform: uppercase;
color: var(–copper); margin-bottom: 8px;
}

.field-group input,
.field-group select,
.field-group textarea {
width: 100%;
background: rgba(8,15,30,0.7);
border: 1px solid rgba(184,115,51,0.2);
color: var(–white);
font-family: ‘Barlow’, sans-serif;
font-size: 15px; font-weight: 300;
padding: 13px 18px;
outline: none;
transition: border-color 0.2s, box-shadow 0.2s;
appearance: none;
-webkit-appearance: none;
}

.field-group input::placeholder,
.field-group textarea::placeholder {
color: rgba(200,192,176,0.35);
}

.field-group input:focus,
.field-group select:focus,
.field-group textarea:focus {
border-color: var(–copper);
box-shadow: 0 0 0 1px rgba(184,115,51,0.2), 0 4px 20px rgba(184,115,51,0.08);
}

.field-group textarea {
resize: vertical; min-height: 90px;
}

.select-wrap { position: relative; }
.select-wrap::after {
content: ‘▾’;
position: absolute; right: 16px; top: 50%; transform: translateY(-50%);
color: var(–copper); pointer-events: none; font-size: 14px;
}
.select-wrap select { padding-right: 40px; cursor: pointer; }
.select-wrap select option { background: var(–navy-mid); color: var(–white); }

/* Radio group */
.radio-group { display: flex; flex-direction: column; gap: 8px; }
.radio-option {
display: flex; align-items: center; gap: 12px;
background: rgba(8,15,30,0.7);
border: 1px solid rgba(184,115,51,0.2);
padding: 12px 16px; cursor: pointer;
transition: all 0.2s;
}
.radio-option:hover {
border-color: rgba(184,115,51,0.45);
background: rgba(26,39,68,0.5);
}
.radio-option input[type=“radio”] {
width: 16px; height: 16px;
accent-color: var(–copper);
flex-shrink: 0;
margin: 0; padding: 0;
border: none;
}
.radio-option span {
font-size: 14px; font-weight: 400; color: var(–white-dim);
}

/* Field row */
.field-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
}

/* ─── BUTTONS ─── */
.form-actions {
display: flex; gap: 12px; margin-top: 36px;
align-items: center;
}

.btn-next {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 14px;
letter-spacing: 0.3em; text-transform: uppercase;
padding: 15px 40px;
background: linear-gradient(135deg, var(–copper), var(–copper-gold));
color: var(–dark); border: none; cursor: pointer;
clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
transition: all 0.25s;
box-shadow: 0 6px 24px rgba(184,115,51,0.25);
flex: 1;
}
.btn-next:hover {
transform: translateY(-1px);
box-shadow: 0 10px 32px rgba(184,115,51,0.4);
}

.btn-back {
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 600; font-size: 13px;
letter-spacing: 0.2em; text-transform: uppercase;
padding: 14px 24px;
background: transparent;
color: var(–white-dim);
border: 1px solid rgba(240,236,228,0.15);
cursor: pointer;
transition: all 0.2s;
clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
}
.btn-back:hover {
color: var(–white); border-color: rgba(240,236,228,0.35);
}

/* Submit button */
.btn-submit {
width: 100%;
font-family: ‘Barlow Condensed’, sans-serif;
font-weight: 700; font-size: 16px;
letter-spacing: 0.35em; text-transform: uppercase;
padding: 18px 40px;
background: linear-gradient(135deg, var(–copper), var(–copper-gold));
color: var(–dark); border: none; cursor: pointer;
clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
transition: all 0.25s;
box-shadow: 0 8px 32px rgba(184,115,51,0.3);
margin-top: 32px;
display: block;
}
.btn-submit:hover {
transform: translateY(-2px);
box-shadow: 0 14px 44px rgba(184,115,51,0.45);
}

/* ─── SUCCESS ─── */
.success-screen {
display: none; text-align: center; padding: 20px 0;
}
.success-icon {
font-size: 56px; margin-bottom: 20px;
}
.success-title {
font-family: ‘Bebas Neue’, sans-serif;
font-size: 48px; letter-spacing: 0.06em;
color: var(–copper-bright); margin-bottom: 12px;
}
.success-text {
font-size: 15px; font-weight: 300;
color: var(–white-dim); line-height: 1.75;
max-width: 360px; margin: 0 auto 32px;
}

/* ─── MOBILE ─── */
@media (max-width: 600px) {
nav { padding: 14px 20px; }
.form-card { padding: 28px 20px; }
.field-row { grid-template-columns: 1fr; }
.form-actions { flex-direction: column-reverse; }
.btn-back { width: 100%; }
.step-line { width: 28px; }
}
</style>

</head>
